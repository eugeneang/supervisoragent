# Copy to ai_news_push.env and fill in (that file is gitignored).
# chmod 600 ai_news_push.env
#
# Shared by: ai_news_push, health_monitor, telegram_bot (supervisor loop).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ANTHROPIC_API_KEY=    # Required for /design and /approve commands in the Telegram bot.

# Optional Network Guardian settings. The guardian is read-only by default.
NETWORK_GUARDIAN_SCAN_SECONDS=300
# Comma-separated Name=host:port health checks, for example:
# NETWORK_GUARDIAN_TARGETS=NAS=192.168.1.10:443,HomeAssistant=192.168.1.20:8123
NETWORK_GUARDIAN_TARGETS=
